{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://iiif.io/api/presentation/4.0/schema/Timeline.json",
    "title": "Timeline",
    "type": "object",
    "allOf": [
        {
            "$ref": "Container.json"
        },
        {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "pattern": "^Timeline$",
                    "default": "Timeline"
                },
                "duration": {
                    "$ref": "properties.json#/$defs/duration"
                }
            },
            "required": [
                "id",
                "type",
                "items",
                "duration"
            ]
        }
    ]
}
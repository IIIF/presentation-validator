{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://iiif.io/api/presentation/4.0/schema/AnnoTarget.json",
    "title": "AnnotationTarget",
    "type": "object",
    "if": {
        "required": [
            "type"
        ],
        "properties": {
            "type": {
                "const": "SpecificResource"
            }
        }
    },
    "then": {
        "$ref": "SpecificResource.json"
    },
    "else": {
        "if": {
            "required": [
                "type"
            ],
            "properties": {
                "type": {
                    "const": "Canvas"
                }
            }
        },
        "then": {
            "$ref": "CanvasRef.json"
        },
        "else": {
            "if": {
                "required": [
                    "type"
                ],
                "properties": {
                    "type": {
                        "const": "Timeline"
                    }
                }
            },
            "then": {
                "$ref": "TimelineRef.json"
            },
            "else": {
                "$ref": "SceneRef.json"
            }
        }
    }
}
{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://iiif.io/api/presentation/4.0/schema/Homepage.json",
    "title": "homepages",
    "type": "array",
    "items": {
        "title": "homepage",
        "type": "object",
        "properties": {
            "id": {
                "$ref": "properties.json#/$defs/id"
            },
            "type": {
                "type": "string",
                "pattern": "^Text$",
                "default": "Text"
            },
            "label": {
                "$ref": "properties.json#/$defs/lngString"
            },
            "format": {
                "$ref": "properties.json#/$defs/format"
            },
            "language": {
                "type": "array",
                "items": {
                    "$ref": "properties.json#/$defs/BCP47"
                }
            }
        },
        "required": [
            "id",
            "type",
            "label"
        ]
    }
}
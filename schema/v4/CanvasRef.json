{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://iiif.io/api/presentation/4.0/schema/CanvasRef.json",
    "title": "CanvasRef",
    "allOf": [
        {
            "$ref": "Reference.json"
        },
        {
            "type": "object",
            "properties": {
                "id": {
                    "$ref": "properties.json#/$defs/id"
                },
                "type": {
                    "type": "string",
                    "pattern": "^Canvas$"
                }
            },
            "required": [
                "id",
                "type"
            ]
        }
    ]
}
{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://iiif.io/api/presentation/4.0/schema/FragmentSelector.json",
    "title": "FragmentSelector",
    "type": "object",
    "properties": {
        "type": {
            "type": "string",
            "pattern": "^FragmentSelector$",
            "default": "FragmentSelector"
        },
        "conformsTo": {
            "type": "string",
            "format": "uri",
            "pattern": "^http.*$",
            "default": "http://www.w3.org/TR/media-frags/"
        },
        "value": {
            "type:": "string"
        }
    },
    "required": [
        "type",
        "value"
    ]
}
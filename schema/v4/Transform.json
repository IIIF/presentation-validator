{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://iiif.io/api/presentation/4.0/schema/Transform.json",
    "title": "Transform",
    "type": "object",
    "properties": {
        "type": {
            "type": "string",
            "enum": [
                "RotateTransform",
                "TranslateTransform",
                "ScaleTransform"
            ]
        },
        "x": {
            "type": "number"
        },
        "y": {
            "type": "number"
        },
        "z": {
            "type": "number"
        }
    },
    "required": [
        "type"
    ]
}
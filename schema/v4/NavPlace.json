{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://iiif.io/api/presentation/4.0/schema/NavPlace.json",
    "title": "NavPlace",
    "type": "object",
    "properties": {
        "id": {
            "$ref": "properties.json#/$defs/id"
        },
        "type": {
            "type": "string",
            "default": "FeatureCollection"
        },
        "features": {
            "type": "array",
            "items": {
                "type": "object"
            }
        }
    },
    "required": [
        "id",
        "type"
    ]
}
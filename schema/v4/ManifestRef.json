{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://iiif.io/api/presentation/4.0/schema/ManifestRef.json",
    "title": "ManifestRef",
    "allOf": [
        {
            "$ref": "Reference.json"
        },
        {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "pattern": "^Manifest$",
                    "default": "Manifest"
                },
                "label": {
                    "$ref": "properties.json#/$defs/lngString"
                }
            },
            "required": [
                "label"
            ]
        }
    ]
}
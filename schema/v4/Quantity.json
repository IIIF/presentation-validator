{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://iiif.io/api/presentation/4.0/schema/Quantity.json",
    "title": "Quantity",
    "type": "object",
    "properties": {
        "type": {
            "type": "string",
            "pattern": "^Scene$",
            "default": "Scene"
        },
        "quantityValue": {
            "type": "number"
        },
        "unit": {
            "type": "string"
        }
    }
}
{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://iiif.io/api/presentation/4.0/schema/PartOf.json",
    "title": "PartOf",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "id": {
                "$ref": "properties.json#/$defs/id"
            },
            "type": {
                "type": "string",
                "enum": [
                    "AnnotationCollection",
                    "Collection",
                    "Manifest"
                ]
            }
        },
        "required": [
            "id",
            "type"
        ],
        "not": {
            "required": [
                "items"
            ]
        }
    }
}